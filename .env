# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
PARSER_STATE_DSN=sqlite:%kernel.project_dir%/var/state/parser.sqlite
PARSER_HTTP_TIMEOUT=10
PARSER_HTTP_MAX_DURATION=30
PARSER_HTTP_RETRY_ATTEMPTS=2
PARSER_HTTP_RETRY_DELAY_MS=500
PARSER_HTTP_MIN_DELAY_MS=0
PARSER_HTTP_JITTER_MS=0
PARSER_HTTP_USER_AGENTS='["Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36","Mozilla/5.0 (Macintosh; Intel Mac OS X 14_4) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.4 Safari/605.1.15","Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36","Mozilla/5.0 (iPhone; CPU iPhone OS 17_4 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.4 Mobile/15E148 Safari/604.1"]'
PARSER_RUN_STATUS_PATH=%kernel.project_dir%/var/status/parser-run.json
PARSER_DIAGNOSTIC_LOG_ENABLED=0
PARSER_DIAGNOSTIC_LOG_PATH=%kernel.project_dir%/var/log/parser-diagnostic.ndjson
PARSER_PENDING_RETRY_DELAY_SECONDS=300
PARSER_PENDING_MAX_ATTEMPTS=5
MAIN_API_BASE_URL=http://host.docker.internal:8080
PARSER_INSTANCE_ID=
PARSER_API_KEY=
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###
